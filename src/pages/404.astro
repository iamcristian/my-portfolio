---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 | Page Not Found" description="Page not found" structuredDataType="collection">
  <main class="min-h-screen bg-base-100 text-base-content flex flex-col items-center justify-center p-4 relative overflow-hidden">
    <!-- Ambient Cosmic Nebula Glows -->
    <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] rounded-full bg-primary/5 blur-[80px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[350px] h-[350px] rounded-full bg-secondary/3 blur-[100px] pointer-events-none"></div>

    <div class="z-10 text-center max-w-lg space-y-6">
      <div class="relative inline-block">
        <h1 class="text-8xl md:text-9xl font-extrabold tracking-widest bg-linear-to-r from-primary via-neutral-content to-secondary bg-clip-text text-transparent opacity-90 select-none">
          404
        </h1>
        <div class="absolute inset-0 bg-linear-to-r from-primary/20 via-neutral-content/20 to-secondary/20 blur-xl -z-10"></div>
      </div>

      <div class="space-y-2">
        <h2 id="error-title" class="text-2xl md:text-3xl font-extrabold tracking-tight">
          Page Not Found
        </h2>
        <p id="error-subtitle" class="text-sm md:text-base opacity-70 leading-relaxed">
          The page you are looking for does not exist or has been moved.
        </p>
      </div>

      <div class="pt-4">
        <a id="back-button" href="/en/" class="btn btn-primary gap-2 transition-all hover:scale-105">
          Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  const translations = {
    en: {
      title: "Page Not Found",
      subtitle: "The page you are looking for does not exist or has been moved.",
      button: "Back to Home",
      homeUrl: "/en/"
    },
    es: {
      title: "Página no encontrada",
      subtitle: "La página que buscas no existe o ha sido movida.",
      button: "Volver al inicio",
      homeUrl: "/es/"
    },
    de: {
      title: "Seite nicht gefunden",
      subtitle: "Die von Ihnen gesuchte Seite existiert nicht oder wurde verschoben.",
      button: "Zurück zur Startseite",
      homeUrl: "/de/"
    },
    ja: {
      title: "ページが見つかりません",
      subtitle: "お探しのページは存在しないか、移動された可能性があります。",
      button: "ホームに戻る",
      homeUrl: "/ja/"
    },
    ru: {
      title: "Страница не найдена",
      subtitle: "Страница, которую вы ищете, не существует или была перемещена.",
      button: "На главную",
      homeUrl: "/ru/"
    }
  };

  function localize404() {
    const pathname = window.location.pathname;
    const match = pathname.match(/^\/(en|es|de|ja|ru)(\/|$)/);
    const lang = match ? match[1] : "en";
    const content = translations[lang as keyof typeof translations] || translations.en;

    const titleEl = document.getElementById("error-title");
    const subtitleEl = document.getElementById("error-subtitle");
    const buttonEl = document.getElementById("back-button") as HTMLAnchorElement;

    if (titleEl) titleEl.textContent = content.title;
    if (subtitleEl) subtitleEl.textContent = content.subtitle;
    if (buttonEl) {
      buttonEl.textContent = content.button;
      buttonEl.href = content.homeUrl;
    }
  }

  localize404();
  document.addEventListener("astro:page-load", localize404);
</script>

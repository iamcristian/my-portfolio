---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { getLocaleStaticPaths } from "@config/paths";
import { useTranslations, getUsesForLang } from "@i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { lang } = Astro.locals;
const t = useTranslations(lang);
const usesCategories = getUsesForLang(lang);
---

<Layout title={`${t("uses.title")} | ${t("home.name")}`} description={t("uses.subtitlePage")} structuredDataType="collection">
  <Header />
  
  <main id="main-content" class="max-w-4xl mx-auto px-4 md:px-8 pt-8 md:pt-12 pb-16 md:pb-24 min-h-screen">
    <!-- Back Button -->
    <div class="mb-6 md:mb-8">
      <a href={getRelativeLocaleUrl(lang, "")} class="btn btn-ghost btn-sm gap-2">
        &larr; {t("uses.back") || "Back"}
      </a>
    </div>

    <!-- Header Section -->
    <header class="space-y-4 mb-12">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-6 bg-primary rounded" />
        <span class="text-xs font-semibold opacity-60 uppercase tracking-wider">{t("uses.subtitle")}</span>
      </div>
      <h1 class="text-2xl md:text-4xl font-extrabold tracking-tight leading-tight">
        {t("uses.title")}
      </h1>
      <p class="text-sm md:text-base opacity-75 max-w-2xl leading-relaxed">
        {t("uses.subtitlePage")}
      </p>
    </header>

    <hr class="border-base-300 my-8" />

    <!-- Gear Categories List -->
    <div class="space-y-12">
      {usesCategories.map((category) => (
        <section class="space-y-6 scroll-reveal transition-all duration-700 ease-out opacity-0 translate-y-8">
          <div class="flex items-center gap-2 border-b border-base-300 pb-2">
            <h2 class="text-lg md:text-xl font-bold text-primary">
              {category.name}
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {category.items.map((item) => (
              <div class="card bg-base-200 border border-base-300 shadow-md p-5 hover:border-primary/30 transition-all group rounded-xl">
                <h3 class="font-bold text-sm md:text-base group-hover:text-primary transition-colors">
                  {item.name}
                </h3>
                <p class="text-xs opacity-75 leading-relaxed mt-2">
                  {item.description}
                </p>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Layout>

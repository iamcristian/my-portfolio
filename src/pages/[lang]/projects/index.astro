---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import ProjectsManager from "../../../components/projects/ProjectsManager.astro";
import Footer from "../../../components/Footer.astro";
import { getLang } from "../../../i18n/utils";
import { getLocaleStaticPaths } from "../../../config/paths";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const lang = getLang(Astro.currentLocale || Astro.params.lang);
---

<Layout>
  <Header />
  <ProjectsManager lang={lang} />
  <Footer />
</Layout>

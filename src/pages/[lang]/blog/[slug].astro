---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import BlogPostDetail from "../../../components/blog/BlogPostDetail.astro";
import Footer from "../../../components/Footer.astro";
import { getCollection } from "astro:content";
import { getLang } from "../../../i18n/utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: post.data.slug },
    props: { post },
  }));
}

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const { post } = Astro.props;

const ogImage = post.data.image ? post.data.image.src : undefined;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  type="article"
  publishDate={post.data.date}
  tags={post.data.tags}
>
  <Header />
  <BlogPostDetail post={post} lang={lang} />
  <Footer />
</Layout>

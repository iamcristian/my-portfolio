---
import { SITE } from "../config/site";
import { resolveSEOData } from "../utils/seo";
import { locales } from "../i18n/ui";
import meImage from "../assets/images/me.webp";

export interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  type?: "website" | "article";
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  structuredDataType?: "profile" | "collection";
  wordCount?: number;
  faq?: Array<{ question: string; answer: string }>;
}

const {
  type = "website",
  publishDate,
  updatedDate,
  tags,
  structuredDataType,
  wordCount,
  faq,
} = Astro.props;

const { lang } = Astro.locals;
const slug = Astro.params.slug;

const seo = resolveSEOData(Astro.props, Astro.url, lang, slug);
const t = seo.t;

// Schemas list
const schemas: any[] = [];

// 1. BreadcrumbList for all pages
const segments = seo.pathname.split("/").filter(Boolean);
let breadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": `${seo.cleanSiteUrl}/${seo.lang}/`
  }
];

if (segments.length > 1) {
  // We are on a subpage (e.g. /en/blog or /en/projects)
  const categorySegment = segments[1];
  if (categorySegment === "blog") {
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${seo.cleanSiteUrl}/${seo.lang}/blog/`
    });
    
    if (segments.length > 2) {
      // Individual blog post
      breadcrumbItems.push({
        "@type": "ListItem",
        "position": 3,
        "name": seo.title,
        "item": seo.canonicalUrl
      });
    }
  } else if (categorySegment === "projects") {
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": "Projects",
      "item": `${seo.cleanSiteUrl}/${seo.lang}/projects/`
    });
  }
}

schemas.push({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
});

// 2. WebSite schema (Only on Home)
if (seo.isHome) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": t("home.name") || SITE.name,
    "url": seo.cleanSiteUrl,
    "inLanguage": locales,
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${seo.cleanSiteUrl}/${seo.lang}/blog/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  });
}

// 3. ProfilePage + Person schema (Only on Home or if structuredDataType === "profile")
if (seo.isHome || structuredDataType === "profile") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": SITE.name,
      "jobTitle": "Full Stack Software Developer",
      "url": `${seo.cleanSiteUrl}/${seo.lang}/`,
      "email": SITE.email,
      "image": new URL(meImage.src, seo.cleanSiteUrl).href,
      "sameAs": [
        SITE.social.github,
        SITE.social.linkedin
      ],
      "knowsLanguage": locales,
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Universidad Mayor de San Simón"
      }
    }
  });
}

// 4. CollectionPage schema (For blog index or projects index)
if (seo.isBlogIndex || seo.isProjects || structuredDataType === "collection") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": seo.title,
    "description": seo.description,
    "url": seo.canonicalUrl,
    "isPartOf": {
      "@type": "WebSite",
      "name": SITE.name,
      "url": seo.cleanSiteUrl
    }
  });
}

// 5. BlogPosting schema (For individual blog post)
if (type === "article") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": seo.title,
    "description": seo.description,
    "image": seo.imageUrl,
    "datePublished": publishDate ? publishDate.toISOString() : undefined,
    "dateModified": updatedDate ? updatedDate.toISOString() : (publishDate ? publishDate.toISOString() : undefined),
    "author": {
      "@type": "Person",
      "name": SITE.name,
      "url": `${seo.cleanSiteUrl}/${seo.lang}/`,
      "sameAs": [
        SITE.social.github,
        SITE.social.linkedin
      ]
    },
    "publisher": {
      "@type": "Person",
      "name": SITE.name,
      "logo": {
        "@type": "ImageObject",
        "url": `${seo.cleanSiteUrl}/favicon.svg`
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": seo.canonicalUrl
    },
    "wordCount": wordCount,
    "articleSection": "Technology",
    "keywords": tags || [],
    "inLanguage": seo.lang
  });
}

// 6. FAQPage schema (If post has FAQ data)
if (faq && faq.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  });
}
---

{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}

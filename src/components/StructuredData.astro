---
import { SITE } from "../config/site";
import { getLang, useTranslations } from "../i18n/utils";
import meImage from "../assets/images/me.webp";

export interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  type?: "website" | "article";
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  structuredDataType?: "profile" | "collection";
  wordCount?: number;
}

const {
  type = "website",
  publishDate,
  updatedDate,
  tags,
  structuredDataType,
  wordCount,
} = Astro.props;

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

const siteUrl = Astro.site?.origin || SITE.url || "https://cristianarando.dev";
const cleanSiteUrl = siteUrl.replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, cleanSiteUrl).href;

// Page route detection
const pathname = Astro.url.pathname;
const isHome = pathname === `/${lang}/` || pathname === `/${lang}` || pathname === "/";
const isProjects = pathname.includes("/projects");
const isBlogIndex = (pathname.endsWith("/blog") || pathname.endsWith("/blog/")) && !Astro.params.slug;

// Resolve default localized title & description for schemas
let title = Astro.props.title;
if (!title) {
  if (isHome) {
    title = `${t("home.name")} — ${t("home.subtitle")}`;
  } else if (isProjects) {
    title = `${t("projects.title")} | ${t("home.name")}`;
  } else if (isBlogIndex) {
    title = `${t("blog.title")} | ${t("home.name")}`;
  } else {
    title = t("site.title") || SITE.title;
  }
}

let description = Astro.props.description;
if (!description) {
  if (isHome) {
    description = t("home.tagline") || t("site.description") || SITE.description;
  } else if (isProjects) {
    description = t("projects.subtitlePage") || t("site.description") || SITE.description;
  } else if (isBlogIndex) {
    description = t("blog.subtitlePage") || t("site.description") || SITE.description;
  } else {
    description = t("site.description") || SITE.description;
  }
}

// Image resolution
const imageSource = Astro.props.image || meImage;
const imageUrl = typeof imageSource === "string"
  ? (imageSource.startsWith("http") ? imageSource : `${cleanSiteUrl}${imageSource}`)
  : new URL(imageSource.src, cleanSiteUrl).href;

// Schemas list
const schemas: any[] = [];

// 1. BreadcrumbList for all pages
const segments = pathname.split("/").filter(Boolean);
// For localized sites, the first segment might be the lang. Remove it or handle it.
const locales = ["en", "es", "de", "ru", "ja"];
let breadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": `${cleanSiteUrl}/${lang}/`
  }
];

if (segments.length > 1) {
  // We are on a subpage (e.g. /en/blog or /en/projects)
  const categorySegment = segments[1];
  if (categorySegment === "blog") {
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${cleanSiteUrl}/${lang}/blog/`
    });
    
    if (segments.length > 2) {
      // Individual blog post
      breadcrumbItems.push({
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": canonicalUrl
      });
    }
  } else if (categorySegment === "projects") {
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": "Projects",
      "item": `${cleanSiteUrl}/${lang}/projects/`
    });
  }
}

schemas.push({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
});

// 2. WebSite schema (Only on Home)
if (isHome) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": t("home.name") || "Cristian Arando",
    "url": cleanSiteUrl,
    "inLanguage": locales,
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${cleanSiteUrl}/${lang}/blog/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  });
}

// 3. ProfilePage + Person schema (Only on Home or if structuredDataType === "profile")
if (isHome || structuredDataType === "profile") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": "Cristian Arando",
      "jobTitle": "Full Stack Software Developer",
      "url": `${cleanSiteUrl}/${lang}/`,
      "email": "crisarandosyse@gmail.com",
      "image": new URL(meImage.src, cleanSiteUrl).href,
      "sameAs": [
        "https://github.com/iamcristian",
        "https://linkedin.com/in/cristianarando"
      ],
      "knowsLanguage": locales,
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Universidad Mayor de San Simón"
      }
    }
  });
}

// 4. CollectionPage schema (For blog index or projects index)
if (isBlogIndex || isProjects || structuredDataType === "collection") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Cristian Arando",
      "url": cleanSiteUrl
    }
  });
}

// 5. BlogPosting schema (For individual blog post)
if (type === "article") {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": imageUrl,
    "datePublished": publishDate ? publishDate.toISOString() : undefined,
    "dateModified": updatedDate ? updatedDate.toISOString() : (publishDate ? publishDate.toISOString() : undefined),
    "author": {
      "@type": "Person",
      "name": "Cristian Arando",
      "url": `${cleanSiteUrl}/${lang}/`,
      "sameAs": [
        "https://github.com/iamcristian",
        "https://linkedin.com/in/cristianarando"
      ]
    },
    "publisher": {
      "@type": "Person",
      "name": "Cristian Arando",
      "logo": {
        "@type": "ImageObject",
        "url": `${cleanSiteUrl}/favicon.svg`
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    "wordCount": wordCount,
    "articleSection": "Technology",
    "keywords": tags || [],
    "inLanguage": lang
  });
}
---

{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}

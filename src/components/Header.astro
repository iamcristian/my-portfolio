---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../i18n/utils";
import ThemeController from "./ThemeController.astro";
import LanguageController from "./LanguageController.astro";
import MenuIcon from "../assets/icons/menu.svg";

const { lang } = Astro.locals;
const t = useTranslations(lang);

const homeUrl = getRelativeLocaleUrl(lang, "");

const NAV_LINKS = [
  { href: `${homeUrl}#home`, label: t("nav.home") },
  { href: `${homeUrl}#about`, label: t("nav.about") },
  { href: `${homeUrl}#education`, label: t("nav.education") },
  { href: `${homeUrl}#experience`, label: t("nav.experience") },
  { href: getRelativeLocaleUrl(lang, "projects"), label: t("nav.projects") },
  { href: `${homeUrl}#skills`, label: t("nav.skills") },
  { href: getRelativeLocaleUrl(lang, "blog"), label: t("nav.blog") },
];
---

<header id="main-header" class="sticky top-0 z-50 backdrop-blur-md bg-base-100/20 border-b border-base-content/5 w-full transition-all duration-300 py-2">
  <nav class="navbar max-w-6xl mx-auto px-4 md:px-8 transition-all duration-300" aria-label="Main navigation">
  <!-- Navbar Start: Burger menu (mobile) + Name -->
  <div class="navbar-start">
    <div class="dropdown lg:hidden">
      <button
        class="btn btn-ghost btn-circle"
        aria-label={t("nav.toggleMenu")}
      >
        <MenuIcon />
      </button>
      <ul
        tabindex="0"
        class="dropdown-content menu menu-sm bg-base-200 text-base-content rounded-box w-32 p-2 shadow-2xl border border-base-content/10 z-50"
      >
        <li class="menu-title text-xs">{t("nav.title")}</li>
        {
          NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <a href={homeUrl} class="lg:text-xl font-bold ml-2 lg:ml-0">{t("home.name")}</a>
  </div>

  <!-- Navbar Center: Navigation links (desktop) -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      {
        NAV_LINKS.map(({ href, label }) => (
          <li>
            <a href={href} class="font-medium">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Navbar End: Theme and Language selectors -->
  <div class="navbar-end gap-2">
    <LanguageController />
    <ThemeController />
  </div>
  </nav>
</header>

<script>
  let headerCleanup: (() => void) | null = null;

  function initHeaderScroll() {
    headerCleanup?.();
    const header = document.getElementById("main-header");
    if (!header) return;

    const handleScroll = () => {
      if (window.scrollY > 20) {
        header.classList.add("py-0.5", "shadow-sm");
        header.classList.remove("py-2");
      } else {
        header.classList.remove("py-0.5", "shadow-sm");
        header.classList.add("py-2");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    headerCleanup = () => {
      window.removeEventListener("scroll", handleScroll);
    };
  }

  initHeaderScroll();

  document.addEventListener("astro:page-load", initHeaderScroll);
  document.addEventListener("astro:before-swap", () => {
    headerCleanup?.();
    headerCleanup = null;
  });
</script>

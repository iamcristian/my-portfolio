---
import { SITE } from "../../config/site";
import GithubIcon from "../../assets/icons/github.svg";
import LinkedinIcon from "../../assets/icons/linkedin.svg";

interface Props {
  /** Icon and button size */
  size?: "sm" | "md";
  /** Whether to show text labels next to icons */
  showLabels?: boolean;
  /** Additional CSS classes for the wrapper */
  class?: string;
  /** Style variant: 'button' or 'link' */
  variant?: "button" | "link";
}

const { size = "md", showLabels = false, class: className, variant = "button" } = Astro.props;

const iconSize = size === "sm" ? "w-4 h-4" : "w-5 h-5";

const isLink = variant === "link";
const wrapperClass = isLink ? "flex flex-col gap-1.5 md:gap-2" : "flex gap-3";
const linkClass = isLink
  ? "link link-hover flex items-center gap-2 text-sm opacity-80 hover:text-primary transition-colors"
  : "btn btn-ghost btn-circle";
---

<div class:list={[wrapperClass, className]}>
  <a
    href={SITE.social.github}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[linkClass]}
    aria-label="GitHub"
  >
    <GithubIcon class={iconSize} />
    {showLabels && <span>GitHub</span>}
  </a>
  <a
    href={SITE.social.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[linkClass]}
    aria-label="LinkedIn"
  >
    <LinkedinIcon class={iconSize} />
    {showLabels && <span>LinkedIn</span>}
  </a>
</div>

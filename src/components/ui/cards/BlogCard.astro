---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../../../i18n/utils";
import { getReadTime } from "../../../utils/blog";
import CalendarIcon from "../../../assets/icons/calendar.svg";
import ClockIcon from "../../../assets/icons/clock.svg";
import ShieldIcon from "../../../assets/icons/shield.svg";
import { Image } from "astro:assets";

interface Props {
  post: CollectionEntry<"blog">;
  isFeatured?: boolean;
  showFeaturedBadge?: boolean;
  loading?: "lazy" | "eager";
  class?: string;
  [key: string]: any;
}

const { post, isFeatured = false, showFeaturedBadge = false, loading = "lazy", class: className, ...rest } = Astro.props;

const { lang } = Astro.locals;
const t = useTranslations(lang);
---

{isFeatured ? (
  <article class="card md:card-side bg-base-200 border border-base-300 shadow-md hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col md:flex-row gap-6 p-6">
    <div class="w-full md:w-5/12 overflow-hidden rounded-lg bg-base-300 relative min-h-[200px] shrink-0">
      <Image
        src={post.data.image}
        alt={post.data.title}
        width={600}
        height={350}
        loading={loading}
        fetchpriority={loading === "eager" ? "high" : undefined}
        class="absolute inset-0 w-full h-full object-cover"
      />
      <span class="badge bg-neutral-900/60 text-white border-none gap-1.5 py-3 px-3.5 absolute top-3 left-3 backdrop-blur-md text-xs font-semibold rounded-full shadow-sm">
        <ShieldIcon class="w-3.5 h-3.5 text-secondary" />
        <span>{t("blog.featured")}</span>
      </span>
    </div>
    <div class="flex-1 flex flex-col justify-start space-y-4">
      <div class="space-y-2">
        <div class="flex gap-4 text-xs text-base-content/80">
          <span class="flex items-center gap-1">
            <CalendarIcon class="w-4 h-4" />
            <span>{new Intl.DateTimeFormat(lang, { dateStyle: 'long' }).format(post.data.date)}</span>
          </span>
          <span class="flex items-center gap-1">
            <ClockIcon class="w-4 h-4" />
            <span>{getReadTime(post.body)} {t("blog.readTime")}</span>
          </span>
        </div>
        <h3 class="card-title text-base md:text-lg font-bold">
          <a href={getRelativeLocaleUrl(lang, `blog/${post.data.slug}`)} class="hover:text-primary transition-colors">
            {post.data.title}
          </a>
        </h3>
        <p class="text-xs opacity-80 line-clamp-3 leading-relaxed">{post.data.description}</p>
        <div class="flex flex-wrap gap-1.5 mt-2">
          {post.data.tags.map((tag) => (
            <span class="badge badge-xs badge-neutral">{tag}</span>
          ))}
        </div>
      </div>
      
      <!-- Bottom Section with Divider -->
      <div class="border-t border-base-300 pt-4 flex items-center justify-between relative">
        <a 
          href={getRelativeLocaleUrl(lang, `blog/${post.data.slug}`)} 
          class="btn btn-outline btn-sm w-fit"
        >
          {t("blog.readMore")}
          <span class="sr-only">: {post.data.title}</span>
        </a>
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center">
          <slot name="carousel-indicators" />
        </div>
      </div>
    </div>
  </article>
) : (
  <article class:list={["blog-card card card-compact bg-base-200 border border-base-300 shadow-md hover:-translate-y-1 transition-transform duration-300 flex flex-col h-full", className]} {...rest}>
    <figure class="blog-figure relative h-44 bg-base-300 shrink-0 transition-all">
      <Image
        src={post.data.image}
        alt={post.data.title}
        width={400}
        height={225}
        loading={loading}
        fetchpriority={loading === "eager" ? "high" : undefined}
        class="w-full h-full object-cover"
      />
      {showFeaturedBadge && (
        <span class="badge bg-neutral-900/60 text-white border-none gap-1.5 py-3 px-3.5 absolute top-3 left-3 backdrop-blur-md text-xs font-semibold rounded-full shadow-sm">
          <ShieldIcon class="w-3.5 h-3.5 text-secondary" />
          <span>{t("blog.featured")}</span>
        </span>
      )}
    </figure>
    <div class="blog-body card-body flex-1 flex flex-col justify-start p-5 transition-all">
      <div class="space-y-3">
        <div class="flex flex-wrap gap-3 text-xs text-base-content/80 items-center">
          {showFeaturedBadge && (
            <span class="blog-metadata-featured-badge badge badge-secondary badge-xs font-semibold gap-1 py-2 px-2 text-[10px] rounded-full shrink-0">
              <ShieldIcon class="w-3 h-3 text-secondary-content" />
              <span>{t("blog.featured")}</span>
            </span>
          )}
          <span class="flex items-center gap-1">
            <CalendarIcon class="w-3.5 h-3.5" />
            <span>{new Intl.DateTimeFormat(lang, { dateStyle: 'medium' }).format(post.data.date)}</span>
          </span>
          <span class="flex items-center gap-1">
            <ClockIcon class="w-3.5 h-3.5" />
            <span>{getReadTime(post.body)} {t("blog.readTime")}</span>
          </span>
        </div>
        <h3 class="card-title text-sm font-bold leading-snug">
          <a href={getRelativeLocaleUrl(lang, `blog/${post.data.slug}`)} class="hover:text-primary transition-colors blog-title">
            {post.data.title}
          </a>
        </h3>
        <p class="text-xs opacity-80 line-clamp-2 leading-relaxed blog-desc">{post.data.description}</p>
        <div class="flex flex-wrap gap-1">
          {post.data.tags.map((tag) => (
            <span class="badge badge-xs badge-neutral">{tag}</span>
          ))}
        </div>
      </div>
      <div class="blog-footer pt-4 border-t border-base-300 mt-4 transition-all">
        <a 
          href={getRelativeLocaleUrl(lang, `blog/${post.data.slug}`)} 
          class="btn btn-outline btn-sm w-fit"
        >
          {t("blog.readMore")}
          <span class="sr-only">: {post.data.title}</span>
        </a>
      </div>
    </div>
  </article>
)}

<style>
  /* Hide the metadata featured badge in grid view (where card-compact class is present) */
  .blog-card.card-compact .blog-metadata-featured-badge {
    display: none !important;
  }
</style>

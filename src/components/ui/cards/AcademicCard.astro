---
import { Image } from "astro:assets";

interface Props {
  item: {
    logo: string;
    institution: string;
    title: string;
    date: string;
    location: string;
    description: string;
  };
}

const { item } = Astro.props;

// Dynamically resolve optimized certificate image from src/assets/images/certs/
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/certs/*.{jpeg,jpg,png,gif,webp}");
const imageImport = images[item.logo]!;
---

<div class="group card card-side bg-base-200 border border-base-300 shadow-md p-4 flex gap-4 items-start hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_20px_rgba(var(--color-primary),0.05)]">
  <div class="avatar placeholder shrink-0 group-hover:scale-110 transition-transform duration-300">
    <div class="bg-base-300 text-neutral-content rounded-lg w-12 h-12 flex items-center justify-center overflow-hidden">
      <Image src={imageImport()} alt={item.institution} width={48} height={48} class="p-1 object-contain" />
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <h3 class="font-bold text-lg group-hover:text-primary transition-colors">{item.title}</h3>
    <p class="text-sm font-medium opacity-80">{item.institution}</p>
    <div class="flex gap-4 mt-2 text-xs opacity-60">
      <span>{item.date}</span>
      <span>{item.location}</span>
    </div>
    <p class="text-sm mt-3 leading-relaxed">{item.description}</p>
  </div>
</div>

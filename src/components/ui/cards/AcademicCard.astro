---
import type { AcademicItem } from "../../../types";
import { useTranslations } from "../../../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";
import { Image } from "astro:assets";
import LinkIcon from "../../../assets/icons/link.svg";

interface Props {
  item: AcademicItem;
}

const { item } = Astro.props;

const { lang } = Astro.locals;
const t = useTranslations(lang);

// Dynamically resolve optimized certificate image from src/assets/images/certs/
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/certs/*.{jpeg,jpg,png,gif,webp}",
);
const imageImport = images[item.logo]!;

const getLinkUrl = (url: string) => {
  if (url.startsWith("http://") || url.startsWith("https://")) {
    return url;
  }
  return getRelativeLocaleUrl(lang, url);
};
---

<div
  class="group card card-side bg-base-200 border border-base-300 shadow-md p-4 flex gap-4 items-start hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_20px_rgba(var(--color-primary),0.05)]"
>
  <div
    class="avatar placeholder shrink-0 group-hover:scale-110 transition-transform duration-300"
  >
    <div
      class="bg-base-300 text-neutral-content rounded-lg w-12 h-12 flex items-center justify-center overflow-hidden"
    >
      <Image
        src={imageImport()}
        alt={item.institution}
        width={48}
        height={48}
        class="p-1 object-contain"
      />
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <h3
      class="font-bold text-sm md:text-base group-hover:text-primary transition-colors"
    >
      {item.title}
    </h3>
    <p class="text-xs font-medium opacity-80">{item.institution}</p>
    <div
      class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-2 text-[10px] sm:text-xs opacity-60"
    >
      <span>{item.date}</span>
      <span class="opacity-40">•</span>
      <span>{item.location}</span>
      {
        item.gpa && (
          <>
            <span class="opacity-40">•</span>
            <span class="badge badge-sm badge-outline badge-primary font-semibold text-[10px] px-1.5 py-0 h-auto">
              {t("education.gpa")}: {item.gpa}
            </span>
          </>
        )
      }
    </div>
    <p class="text-xs md:text-sm mt-3 leading-relaxed">{item.description}</p>
    {
      item.link && (
        <div class="mt-3">
          <a
            href={getLinkUrl(item.link.url)}
            target={item.link.url.startsWith("http") ? "_blank" : undefined}
            rel={
              item.link.url.startsWith("http")
                ? "noopener noreferrer"
                : undefined
            }
            class="link link-primary text-[10px] sm:text-xs font-semibold inline-flex items-center gap-1 hover:underline"
          >
            <LinkIcon class="w-3.5 h-3.5" />
            {item.link.text} &rarr;
          </a>
        </div>
      )
    }
  </div>
</div>

---
interface Props {
  item: {
    logo: string;
    institution: string;
    title: string;
    date: string;
    location: string;
    description: string;
  };
}

const { item } = Astro.props;
---

<div class="card card-side bg-base-200 border border-base-300 shadow-md p-4 flex gap-4 items-start">
  <div class="avatar placeholder shrink-0">
    <div class="bg-base-300 text-neutral-content rounded-lg w-12 h-12">
      <img src={item.logo} alt={item.institution} class="p-1 object-contain" />
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <h3 class="font-bold text-lg">{item.title}</h3>
    <p class="text-sm font-medium opacity-80">{item.institution}</p>
    <div class="flex gap-4 mt-2 text-xs opacity-60">
      <span>{item.date}</span>
      <span>{item.location}</span>
    </div>
    <p class="text-sm mt-3 leading-relaxed">{item.description}</p>
  </div>
</div>

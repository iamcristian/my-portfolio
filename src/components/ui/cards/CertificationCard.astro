---
import { getLang, useTranslations } from "../../../i18n/utils";
import type { Certification } from "../../../types";
import { Image } from "astro:assets";

interface Props {
  item: Certification;
}

const { item } = Astro.props;

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

// Dynamically resolve optimized certificate image from src/assets/images/certs/
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/certs/*.{jpeg,jpg,png,gif,webp}");
const imageImport = images[item.logo];
---

<div class="card bg-base-200 border border-base-300 shadow-sm p-4 flex flex-row gap-4 items-start hover:border-primary/45 transition-colors">
  <div class="avatar placeholder shrink-0">
    <div class="bg-base-300 rounded-lg w-12 h-12 flex items-center justify-center overflow-hidden">
      {imageImport ? (
        <Image src={imageImport()} alt={item.institution} width={48} height={48} class="p-1 object-contain w-full h-full" />
      ) : (
        <Image src={item.logo} alt={item.institution} width={48} height={48} class="p-1 object-contain w-full h-full" />
      )}
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <h5 class="font-bold text-sm leading-snug">{item.title}</h5>
    <p class="text-xs opacity-75 mt-0.5">{item.institution} · {item.date}</p>
    <p class="text-xs mt-2 opacity-80 leading-relaxed">{item.description}</p>
    {item.link && (
      <a
        href={item.link}
        target="_blank"
        rel="noopener noreferrer"
        class="link link-primary text-xs font-semibold inline-flex items-center gap-1 mt-2 hover:underline"
      >
        {t("education.viewCredential")} &rarr;
      </a>
    )}
  </div>
</div>

---
import { getLang, useTranslations } from "../../../i18n/utils";
import type { Project } from "../../../types";
import { Image } from "astro:assets";

interface Props {
  project: Project;
  loading?: "lazy" | "eager";
  class?: string;
  [key: string]: any;
}

const { project, loading = "lazy", class: className, ...rest } = Astro.props;

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

// Dynamically resolve optimized project image from src/assets/images/projects/
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/projects/*.{jpeg,jpg,png,gif,webp}");
const imageImport = images[project.image];
---

<article class:list={["project-card card card-compact bg-base-200 border border-base-300 shadow-xl overflow-hidden hover:-translate-y-1 transition-transform duration-300 flex flex-col h-full", className]} {...rest}>
  <figure class="project-figure relative h-48 bg-base-300 shrink-0 transition-all">
    {imageImport ? (
      <Image
        src={imageImport()}
        alt={project.title}
        width={400}
        height={225}
        loading={loading}
        fetchpriority={loading === "eager" ? "high" : undefined}
        class="w-full h-full object-cover"
      />
    ) : (
      <Image
        src={project.image}
        alt={project.title}
        width={400}
        height={225}
        loading={loading}
        fetchpriority={loading === "eager" ? "high" : undefined}
        class="w-full h-full object-cover"
      />
    )}
  </figure>
  <div class="project-body card-body flex-1 flex flex-col justify-between p-5 transition-all">
    <div class="space-y-3">
      <h3 class="card-title text-lg hover:text-primary transition-colors project-title">{project.title}</h3>
      <p class="text-sm opacity-80 line-clamp-3 leading-relaxed project-desc">{project.description}</p>
      <div class="flex flex-wrap gap-1 mt-2">
        {project.tech.map((techItem) => (
          <span class="badge badge-sm badge-neutral">{techItem}</span>
        ))}
      </div>
    </div>
    <div class="project-footer card-actions justify-start gap-2 pt-4 mt-auto border-t border-base-300 transition-all">
      <a href={project.github} target="_blank" class="btn btn-xs btn-outline">
        {t("projects.code")}
      </a>
      {project.live && (
        <a href={project.live} target="_blank" class="btn btn-xs btn-primary">
          {t("projects.demo")}
        </a>
      )}
    </div>
  </div>
</article>

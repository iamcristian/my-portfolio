---
import { Image } from "astro:assets";

interface Props {
  item: {
    logo: string;
    name: string;
    description: string;
  };
}

const { item } = Astro.props;

// Dynamically resolve optimized language flag from src/assets/images/languages/
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/languages/*.{jpeg,jpg,png,gif,webp}");
const imageImport = images[item.logo]!;
---

<div class="group card bg-base-200/50 backdrop-blur-md border border-base-300 hover:border-primary/50 p-6 text-center items-center transition-all duration-300 hover:shadow-[0_0_20px_rgba(var(--color-primary),0.05)]">
  <!-- Flag container with hover scale and gradient border -->
  <div class="relative w-16 h-16 mb-4 rounded-full p-[3px] bg-linear-to-tr from-primary to-secondary group-hover:scale-110 transition-transform duration-300 shrink-0 shadow-md">
    <div class="w-full h-full rounded-full overflow-hidden border-2 border-base-200 shrink-0">
      <Image src={imageImport()} alt={item.name} width={48} height={32} class="w-full h-full object-cover" />
    </div>
  </div>
  
  <h3 class="font-bold text-lg group-hover:text-primary transition-colors">{item.name}</h3>
  <span class="badge badge-outline text-xs mt-1 px-3 py-1.5">{item.description}</span>
</div>

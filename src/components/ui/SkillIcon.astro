---
import CodeIcon from "../../assets/icons/code.svg";
import MonitorIcon from "../../assets/icons/monitor.svg";
import ServerIcon from "../../assets/icons/server.svg";
import DatabaseIcon from "../../assets/icons/database.svg";
import TerminalIcon from "../../assets/icons/terminal.svg";
import ShieldIcon from "../../assets/icons/shield.svg";
import CpuIcon from "../../assets/icons/cpu.svg";
import PaletteIcon from "../../assets/icons/palette.svg";
import WrenchIcon from "../../assets/icons/wrench.svg";
import CloudIcon from "../../assets/icons/cloud.svg";
import GlobeIcon from "../../assets/icons/globe.svg";
import BrainIcon from "../../assets/icons/brain.svg";
import SparklesIcon from "../../assets/icons/sparkles.svg";

interface Props {
  name?: string;
  class?: string;
}

const { name, class: className } = Astro.props;
---

{name === "code" && <CodeIcon class={className} />}
{name === "monitor" && <MonitorIcon class={className} />}
{name === "server" && <ServerIcon class={className} />}
{name === "database" && <DatabaseIcon class={className} />}
{name === "terminal" && <TerminalIcon class={className} />}
{name === "shield" && <ShieldIcon class={className} />}
{name === "cpu" && <CpuIcon class={className} />}
{name === "palette" && <PaletteIcon class={className} />}
{name === "wrench" && <WrenchIcon class={className} />}
{name === "cloud" && <CloudIcon class={className} />}
{name === "globe" && <GlobeIcon class={className} />}
{name === "brain" && <BrainIcon class={className} />}
{name === "sparkles" && <SparklesIcon class={className} />}

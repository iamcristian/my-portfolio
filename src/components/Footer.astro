---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLang, useTranslations } from "../i18n/utils";
import { SITE } from "../config/site";
import SocialLinks from "./ui/SocialLinks.astro";
import MailIcon from "../assets/mail.svg";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const homeUrl = getRelativeLocaleUrl(lang, "");
---

<footer class="bg-base-200 text-base-content border-t border-base-content/10 mt-auto">
  <!-- Main Footer Content -->
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-16 footer md:footer-horizontal gap-10 justify-between">
    <!-- Column 1: Info -->
    <div class="max-w-xs space-y-3">
      <h3 class="font-bold text-lg text-base-content">{t("home.name")}</h3>
      <p class="text-sm opacity-80 font-medium leading-snug">{t("home.subtitle")}</p>
      <p class="text-sm opacity-70 leading-relaxed">
        {t("footer.tagline")}
      </p>
    </div>

    <!-- Column 2: Quick Links -->
    <div>
      <h6 class="footer-title opacity-60 font-semibold tracking-wider text-xs uppercase mb-3">{t("footer.quickLinks")}</h6>
      <div class="flex flex-col gap-2">
        <a href={homeUrl} class="link link-hover text-sm opacity-80 hover:text-primary transition-colors">{t("nav.home")}</a>
        <a href={`${homeUrl}#about`} class="link link-hover text-sm opacity-80 hover:text-primary transition-colors">{t("nav.about")}</a>
        <a href={getRelativeLocaleUrl(lang, "projects")} class="link link-hover text-sm opacity-80 hover:text-primary transition-colors">{t("nav.projects")}</a>
        <a href={getRelativeLocaleUrl(lang, "blog")} class="link link-hover text-sm opacity-80 hover:text-primary transition-colors">{t("nav.blog")}</a>
      </div>
    </div>

    <!-- Column 3: Connect -->
    <div>
      <h6 class="footer-title opacity-60 font-semibold tracking-wider text-xs uppercase mb-3">{t("footer.connect")}</h6>
      <SocialLinks size="sm" showLabels={true} class="flex-col" />
      <a 
        href={`mailto:${SITE.email}`}
        class="link link-hover flex items-center gap-2 text-sm opacity-80 hover:text-primary transition-colors mt-2"
      >
        <MailIcon class="w-4 h-4" />
        <span>Email</span>
      </a>
    </div>

    <!-- Column 4: Let's Collaborate -->
    <div class="max-w-xs space-y-3">
      <h6 class="footer-title opacity-60 font-semibold tracking-wider text-xs uppercase mb-1">{t("footer.collaborate")}</h6>
      <p class="text-sm opacity-70 leading-relaxed">
        {t("footer.collaborateText")}
      </p>
      <div>
        <a 
          href={`mailto:${SITE.email}`}
          class="btn btn-neutral btn-sm gap-2 mt-2 rounded-lg font-medium shadow-md transition-all hover:scale-105"
        >
          <MailIcon class="w-4 h-4" />
          <span>{t("contact.sendEmail")}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-base-content/10 bg-base-200/50">
    <div class="max-w-6xl mx-auto px-4 md:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs opacity-75">
      <div>
        <p>{t("footer.rights")}</p>
      </div>
      <div class="flex items-center gap-1 font-medium">
        <span>{t("footer.builtWith")}</span>
        <span class="text-error">❤️</span>
      </div>
      <div>
        <a 
          href="#" 
          id="back-to-top" 
          class="link link-hover flex items-center gap-1 font-medium transition-colors hover:text-primary"
        >
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            class="w-3.5 h-3.5" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <path d="m18 15-6-6-6 6"/>
          </svg>
          <span>{t("footer.backToTop")}</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>

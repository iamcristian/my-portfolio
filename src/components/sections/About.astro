---
import { useTranslations } from "../../i18n/utils";
import { defaultLang } from "../../i18n/ui";

const lang = (Astro.currentLocale || defaultLang) as any;
const t = useTranslations(lang);
---

<section id="about" class="py-16 md:py-24 max-w-6xl mx-auto px-4 md:px-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 items-center">
    <!-- Columna de Información -->
    <div class="lg:col-span-2 space-y-6">
      <div>
        <span class="font-mono text-xs tracking-widest uppercase text-primary mb-2 block">{t("about.subtitle")}</span>
        <h2 class="text-3xl lg:text-4xl font-bold">{t("about.title")}</h2>
        <div class="w-12 h-1 bg-primary mt-3 rounded-full"></div>
      </div>
      
      <div class="space-y-4 opacity-90 leading-relaxed">
        <p>{t("about.p1")}</p>
        <p>{t("about.p2")}</p>
        <p>{t("about.p3")}</p>
      </div>
      
      <div class="flex items-center gap-2 text-sm opacity-75">
        <span class="badge badge-outline">{t("about.location")}</span>
      </div>
      
      <!-- Tarjetas de Métricas -->
      <div class="stats stats-vertical md:stats-horizontal shadow bg-base-200 w-full mt-6">
        <div class="stat place-items-center text-center">
          <div class="stat-value text-primary">{t("about.expValue")}</div>
          <div class="stat-title text-sm mt-1">{t("about.expTitle")}</div>
        </div>
        <div class="stat place-items-center text-center">
          <div class="stat-value text-secondary">{t("about.passionValue")}</div>
          <div class="stat-title text-sm mt-1">{t("about.passionTitle")}</div>
        </div>
        <div class="stat place-items-center text-center">
          <div class="stat-value text-accent">{t("about.stratValue")}</div>
          <div class="stat-title text-sm mt-1">{t("about.stratTitle")}</div>
        </div>
      </div>
    </div>
    
    <!-- Columna de Foto -->
    <div class="flex justify-center">
      <div class="relative">
        <div class="absolute -inset-4 rounded-2xl border border-base-content/10 opacity-60"></div>
        <div class="absolute -inset-8 rounded-3xl border border-base-content/5 opacity-40"></div>
        
        <div class="relative w-64 h-64 lg:w-72 lg:h-72 rounded-2xl overflow-hidden shadow-2xl border border-base-300">
          <img src="/images/me.webp" alt="Cristian Arando" class="w-full h-full object-cover" />
        </div>
        
        <div class="absolute -bottom-2 -right-2 w-6 h-6 border-b-2 border-r-2 border-primary rounded-br-lg"></div>
        <div class="absolute -top-2 -left-2 w-6 h-6 border-t-2 border-l-2 border-primary rounded-tl-lg"></div>
      </div>
    </div>
  </div>
</section>

---
import {
  getLang,
  useTranslations,
  getEducationForLang,
  getCertificationsForLang,
  getLanguagesForLang,
} from "../../i18n/utils";
import SectionHeading from "../ui/SectionHeading.astro";
import AcademicCard from "../ui/cards/AcademicCard.astro";
import CertificationCard from "../ui/cards/CertificationCard.astro";
import LanguageCard from "../ui/cards/LanguageCard.astro";

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

const academicEducation = getEducationForLang(lang);
const certifications = getCertificationsForLang(lang);
const localizedLanguages = getLanguagesForLang(lang);
---

<section id="education" class="py-16 md:py-24 max-w-6xl mx-auto px-4 md:px-8">
  <SectionHeading
    subtitle={t("education.subtitle")}
    title={t("education.title")}
  />

  <!-- Main Radio-based CSS Tabs (Lifted) -->
  <div class="tabs tabs-lifted justify-center w-full">
    <!-- TAB 1: Academic Background -->
    <input
      type="radio"
      name="edu_tabs"
      class="tab text-sm font-semibold text-nowrap"
      aria-label={t("education.tabAcademic")}
      checked="checked"
    />
    <div
      class="tab-content bg-base-100 border-base-300 rounded-box p-6 space-y-6"
    >
      {academicEducation.map((item) => <AcademicCard item={item} />)}
    </div>

    <!-- TAB 2: Certifications -->
    <input
      type="radio"
      name="edu_tabs"
      class="tab text-sm font-semibold text-nowrap"
      aria-label={t("education.tabCerts")}
    />
    <div
      class="tab-content bg-base-100 border-base-300 rounded-box p-6 space-y-6 max-h-[600px] overflow-y-auto"
    >
      <!-- Nested Sub-tabs for certification categories -->
      <div class="tabs tabs-bordered justify-center w-full">
        <!-- Sub-Tab 1: All -->
        <input
          type="radio"
          name="cert_tabs"
          class="tab"
          aria-label={t("education.certsAll")}
          checked="checked"
        />
        <div class="tab-content p-4 space-y-8 mt-2 w-full">
          {
            certifications.map((category) => (
              <div class="space-y-4">
                <div class="flex items-center gap-2 border-b border-base-300 pb-2">
                  <span class="w-1.5 h-4 bg-primary rounded" />
                  <h4 class="font-bold text-xs uppercase tracking-wider opacity-80">
                    {category.name}
                  </h4>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {category.items.map((item) => (
                    <CertificationCard item={item} />
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Sub-Tabs 2+: Individual categories -->
        {
          certifications.map((category) => (
            <>
              <input
                type="radio"
                name="cert_tabs"
                class="tab"
                aria-label={category.name}
              />
              <div
                class="tab-content p-4 space-y-8 mt-2 w-full"
              >
                <div class="space-y-4">
                  <div class="flex items-center gap-2 border-b border-base-300 pb-2">
                    <span class="w-1.5 h-4 bg-primary rounded" />
                    <h4 class="font-bold text-xs uppercase tracking-wider opacity-80">
                      {category.name}
                    </h4>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {category.items.map((item) => (
                      <CertificationCard item={item} />
                    ))}
                  </div>
                </div>
              </div>
            </>
          ))
        }
      </div>
    </div>

    <!-- TAB 3: Languages -->
    <input
      type="radio"
      name="edu_tabs"
      class="tab text-sm font-semibold text-nowrap"
      aria-label={t("education.tabLanguages")}
    />
    <div
      class="tab-content bg-base-100 border-base-300 rounded-box p-6"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        {localizedLanguages.map((item) => <LanguageCard item={item} />)}
      </div>
    </div>
  </div>
</section>

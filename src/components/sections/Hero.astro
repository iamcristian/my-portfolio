---
import { getLang, useTranslations } from "../../i18n/utils";
import { SITE } from "../../config/site";
import SocialLinks from "../ui/SocialLinks.astro";
import DownloadIcon from "../../assets/icons/download.svg";
import MailIcon from "../../assets/icons/mail.svg";

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

const cvPath = SITE.cv[lang] || SITE.cv.en;
---

<section id="home" class="hero min-h-[calc(100vh-4rem)] bg-base-100 relative overflow-hidden">
  <!-- Grid Pattern Background -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(currentColor 1px, transparent 1px), linear-gradient(90deg, currentColor 1px, transparent 1px); background-size: 4rem 4rem;"></div>
  
  <div class="hero-content flex-col lg:flex-row gap-12 lg:gap-16 max-w-6xl w-full justify-between px-4 md:px-8 mx-auto">
    <!-- Left Column: Text & CTAs -->
    <div class="flex flex-col gap-6 text-center lg:text-left max-w-xl">
      <div>
        <span class="font-mono text-sm tracking-widest uppercase text-primary font-semibold block mb-2">
          {t("home.hello")}
        </span>
        <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight">
          <span class="bg-linear-to-r from-primary via-neutral-content to-secondary bg-clip-text text-transparent">
            {t("home.name")}
          </span>
        </h1>
      </div>
      <h2 class="text-xl lg:text-2xl font-semibold opacity-90">
        {t("home.subtitle")}
      </h2>
      <p class="text-md lg:text-lg opacity-75 leading-relaxed">
        {t("home.tagline")}
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 justify-center lg:justify-start mt-4">
        <a href={cvPath} class="btn btn-primary gap-2" target="_blank">
          <DownloadIcon class="w-5 h-5" />
          <span>{t("home.downloadCv")}</span>
        </a>
        <a href={`mailto:${SITE.email}`} class="btn btn-outline gap-2">
          <MailIcon class="w-5 h-5" />
          <span>{t("home.contactMe")}</span>
        </a>
      </div>
      
      <!-- Social Links -->
      <SocialLinks class="justify-center lg:justify-start mt-2" />
    </div>
    
    <!-- Right Column: Decorative Element (Hidden on mobile) -->
    <div class="hidden lg:flex justify-center items-center relative w-80 h-80">
      <div class="absolute inset-0 rounded-full border border-base-content/10 animate-[spin_20s_linear_infinite]"></div>
      <div class="absolute inset-4 rounded-full border border-base-content/20 animate-[spin_15s_linear_infinite_reverse]"></div>
      
      <div class="absolute inset-12 rounded-full bg-base-200/50 backdrop-blur-md border border-base-content/10 flex items-center justify-center shadow-xl">
        <div class="text-center">
          <span class="font-mono text-3xl font-bold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent">&lt;/&gt;</span>
          <div class="font-mono text-xs opacity-50 mt-1">dev</div>
        </div>
      </div>
    </div>
  </div>
</section>

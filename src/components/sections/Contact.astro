---
import { getLang, useTranslations } from "../../i18n/utils";
import { SITE } from "../../config/site";
import MailIcon from "../../assets/mail.svg";
import SectionHeading from "../ui/SectionHeading.astro";
import SocialLinks from "../ui/SocialLinks.astro";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section id="contact" class="py-16 md:py-24 relative overflow-hidden bg-base-100">
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, currentColor 1px, transparent 1px); background-size: 3rem 3rem;"></div>
  
  <div class="max-w-2xl mx-auto text-center space-y-8 relative z-10 px-4">
    <SectionHeading subtitle={t("contact.subtitle")} title={t("contact.title")} />

    <p class="text-lg opacity-85 leading-relaxed">{t("contact.tagline")}</p>

    <div class="flex justify-center mt-4">
      <a href={`mailto:${SITE.email}`} class="btn btn-primary btn-lg gap-2 shadow-lg">
        <MailIcon class="w-6 h-6" />
        <span>{t("contact.sendEmail")}</span>
      </a>
    </div>

    <!-- Social links -->
    <div class="flex justify-center pt-4">
      <SocialLinks size="md" />
    </div>
  </div>
</section>

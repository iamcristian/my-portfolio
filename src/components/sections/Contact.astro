---
import { useTranslations } from "../../i18n/utils";
import { defaultLang } from "../../i18n/ui";

// SVGs
import MailIcon from "../../assets/mail.svg";
import GithubIcon from "../../assets/github.svg";
import LinkedinIcon from "../../assets/linkedin.svg";

const lang = (Astro.currentLocale || defaultLang) as any;
const t = useTranslations(lang);
---

<section id="contact" class="py-16 md:py-24 relative overflow-hidden bg-base-100">
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, currentColor 1px, transparent 1px); background-size: 3rem 3rem;"></div>
  
  <div class="max-w-2xl mx-auto text-center space-y-8 relative z-10 px-4">
    <div>
      <span class="font-mono text-xs tracking-widest uppercase text-primary mb-2 block">{t("contact.subtitle")}</span>
      <h2 class="text-3xl lg:text-4xl font-bold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent">
        {t("contact.title")}
      </h2>
      <div class="w-12 h-1 bg-primary mt-3 mx-auto rounded-full"></div>
    </div>

    <p class="text-lg opacity-85 leading-relaxed">{t("contact.tagline")}</p>

    <div class="flex justify-center mt-4">
      <a href="mailto:crisarandosyse@gmail.com" class="btn btn-primary btn-lg gap-2 shadow-lg">
        <MailIcon class="w-6 h-6" />
        <span>{t("contact.sendEmail")}</span>
      </a>
    </div>

    <!-- Social links -->
    <div class="flex justify-center gap-4 pt-4">
      <a href="https://github.com/iamcristian" target="_blank" class="btn btn-ghost btn-circle" aria-label="GitHub">
        <GithubIcon class="w-5 h-5" />
      </a>
      <a href="https://linkedin.com/in/cristianarando" target="_blank" class="btn btn-ghost btn-circle" aria-label="LinkedIn">
        <LinkedinIcon class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>

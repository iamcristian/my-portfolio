---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations, getProjectsForLang } from "../../i18n/utils";
import ProjectCard from "../ui/cards/ProjectCard.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const { lang } = Astro.locals;
const t = useTranslations(lang);

const PROJECTS = getProjectsForLang(lang);
const featuredProjects = PROJECTS.filter((p) => p.featured).slice(0, 3);
---

<section id="projects" class="py-16 md:py-24 max-w-6xl mx-auto px-4 md:px-8 scroll-reveal transition-all duration-700 ease-out opacity-0 translate-y-8">
  <SectionHeading subtitle={t("projects.subtitle")} title={t("projects.title")} />

  <!-- Grid de Tarjetas -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))
    }
  </div>

  <div class="text-center mt-10">
    <a href={getRelativeLocaleUrl(lang, "projects")} class="btn btn-outline">
      {t("projects.viewAll")}
    </a>
  </div>
</section>

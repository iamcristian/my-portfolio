---
import { getLang, useTranslations, getSkillsForLang } from "../../i18n/utils";
import SectionHeading from "../ui/SectionHeading.astro";

const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);
const skillsCategories = getSkillsForLang(lang);
---

<section id="skills" class="py-16 md:py-24 max-w-6xl mx-auto px-4 md:px-8">
  <SectionHeading subtitle={t("skills.subtitle")} title={t("skills.title")} />

  <!-- Grid de Categorías -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      skillsCategories.map((category) => (
        <div class="card bg-base-200 border border-base-300 p-6">
          <h3 class="font-bold text-lg text-primary mb-4">{category.name}</h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => (
              <span class="badge badge-neutral">{item}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

---
import ThemeController from "./theme-controller.astro";
import LanguageController from "./language-controller.astro";
import MenuIcon from "../../assets/menu.svg";

const NAV_LINKS = [
  { href: "#home", label: "Home" },
  { href: "#about", label: "About" },
  { href: "#education", label: "Education" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#skills", label: "Skills" },
  { href: "#blog", label: "Blog" },
];
---

<header class="navbar bg-base-200 shadow-sm px-4 lg:px-8">
  <!-- Navbar Start: Burger menu (mobile) + Name -->
  <div class="navbar-start">
    <div class="dropdown lg:hidden">
      <button
        class="btn btn-ghost btn-circle"
        aria-label="Toggle Navigation Menu"
      >
        <MenuIcon />
      </button>
      <ul
        tabindex="0"
        class="dropdown-content menu menu-sm bg-base-200 text-base-content rounded-box mt-3 w-32 p-2 shadow-2xl border border-base-content/10 z-50"
      >
        {
          NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <a href="/" class="text-xl font-bold ml-2 lg:ml-0">Cristian Arando</a>
  </div>

  <!-- Navbar Center: Navigation links (desktop) -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      {
        NAV_LINKS.map(({ href, label }) => (
          <li>
            <a href={href} class="font-medium">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Navbar End: Theme and Language selectors -->
  <div class="navbar-end gap-2">
    <LanguageController />
    <ThemeController />
  </div>
</header>

---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../../i18n/utils";
import { defaultLang } from "../../i18n/ui";
import ThemeController from "./theme-controller.astro";
import LanguageController from "./language-controller.astro";
import MenuIcon from "../../assets/menu.svg";

const lang = (Astro.currentLocale || defaultLang) as any;
const t = useTranslations(lang);

const homeUrl = getRelativeLocaleUrl(lang, "");

const NAV_LINKS = [
  { href: `${homeUrl}#home`, label: t("nav.home") },
  { href: `${homeUrl}#about`, label: t("nav.about") },
  { href: `${homeUrl}#education`, label: t("nav.education") },
  { href: `${homeUrl}#experience`, label: t("nav.experience") },
  { href: getRelativeLocaleUrl(lang, "projects"), label: t("nav.projects") },
  { href: `${homeUrl}#skills`, label: t("nav.skills") },
  { href: getRelativeLocaleUrl(lang, "blog"), label: t("nav.blog") },
];
---

<header class="navbar sticky top-0 z-50 backdrop-blur-md bg-base-200/80 border-b border-base-content/10 px-4 lg:px-8">
  <!-- Navbar Start: Burger menu (mobile) + Name -->
  <div class="navbar-start">
    <div class="dropdown lg:hidden">
      <button
        class="btn btn-ghost btn-circle"
        aria-label={t("nav.toggleMenu")}
      >
        <MenuIcon />
      </button>
      <ul
        tabindex="0"
        class="dropdown-content menu menu-sm bg-base-200 text-base-content rounded-box mt-3 w-32 p-2 shadow-2xl border border-base-content/10 z-50"
      >
        {
          NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <a href={homeUrl} class="text-xl font-bold ml-2 lg:ml-0">Cristian Arando</a>
  </div>

  <!-- Navbar Center: Navigation links (desktop) -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      {
        NAV_LINKS.map(({ href, label }) => (
          <li>
            <a href={href} class="font-medium">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Navbar End: Theme and Language selectors -->
  <div class="navbar-end gap-2">
    <LanguageController />
    <ThemeController />
  </div>
</header>

---
import { getLang, useTranslations, getProjectsForLang } from "../../i18n/utils";
import ProjectCard from "../ui/cards/ProjectCard.astro";
import PageHeading from "../ui/PageHeading.astro";

// SVGs
import SearchIcon from "../../assets/search.svg";
import GridIcon from "../../assets/grid.svg";
import ListIcon from "../../assets/list.svg";
import SortIcon from "../../assets/sort.svg";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const langCode = getLang(lang || Astro.params.lang);
const t = useTranslations(langCode);
const PROJECTS = getProjectsForLang(langCode).sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<main class="max-w-6xl mx-auto px-4 md:px-8 pt-8 md:pt-12 pb-16 md:pb-24 flex flex-col gap-8 min-h-screen">
  <!-- Header -->
  <PageHeading subtitle={t("projects.subtitle")} title={t("projects.title")} description={t("projects.subtitlePage")} />

  <!-- Controls: Search, View Toggle, Category Filters, Sort -->
  <div class="flex flex-col gap-6 bg-base-200 p-6 rounded-2xl border border-base-300">
    
    <!-- Top Row: Search + View Toggle -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
      <!-- Search input group -->
      <div class="relative w-full sm:max-w-md">
        <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none opacity-60">
          <SearchIcon class="w-5 h-5" />
        </span>
        <input
          type="text"
          id="projects-search"
          class="input input-bordered w-full pl-10 bg-base-100"
          placeholder={t("projects.searchPlaceholder")}
        />
      </div>

      <!-- View Toggle (Grid / List) using DaisyUI join -->
      <div class="join shrink-0">
        <button id="view-grid-btn" class="btn join-item btn-active btn-square" aria-label={t("projects.viewGrid")}>
          <GridIcon class="w-5 h-5" />
        </button>
        <button id="view-list-btn" class="btn join-item btn-square" aria-label={t("projects.viewList")}>
          <ListIcon class="w-5 h-5" />
        </button>
      </div>
    </div>

    <!-- Bottom Row: Category Filters + Sort Select -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center border-t border-base-300 pt-4">
      <!-- Category Buttons -->
      <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
        <button class="btn btn-sm btn-neutral cat-btn active" data-category="all">{t("projects.all")}</button>
        <button class="btn btn-sm btn-outline cat-btn" data-category="frontend">{t("projects.frontend")}</button>
        <button class="btn btn-sm btn-outline cat-btn" data-category="backend">{t("projects.backend")}</button>
        <button class="btn btn-sm btn-outline cat-btn" data-category="fullstack">{t("projects.fullstack")}</button>
      </div>

      <!-- Sort dropdown -->
      <div class="flex items-center gap-2">
        <SortIcon class="w-5 h-5 opacity-60" />
        <select id="projects-sort" class="select select-bordered select-sm bg-base-100">
          <option value="date-desc">{t("projects.sortDateNewest")}</option>
          <option value="date-asc">{t("projects.sortDateOldest")}</option>
          <option value="name-asc">{t("projects.sortNameAsc")}</option>
          <option value="name-desc">{t("projects.sortNameDesc")}</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Projects Container -->
  <div id="projects-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[300px]">
    {
      PROJECTS.map((project, index) => {
        const title = project.title;
        const description = project.description;
        return (
          <ProjectCard
            project={project}
            loading={index < 6 ? "eager" : "lazy"}
            data-id={project.id}
            data-category={project.category}
            data-date={project.date}
            data-name={title.toLowerCase()}
            data-tech={project.tech.join(" ").toLowerCase()}
            data-description={description.toLowerCase()}
          />
        );
      })
    }
  </div>

  <!-- Empty State -->
  <div id="no-results-state" class="hidden text-center py-12">
    <p class="text-lg opacity-70">{t("projects.noResults")}</p>
  </div>

  <!-- Pagination -->
  <div class="flex justify-center mt-8" id="pagination-wrapper">
    <div class="join" id="pagination-controls"></div>
  </div>
</main>

<script>
  import { initListManager } from "../../scripts/list-manager";

  function setup() {
    initListManager({
      containerId: "projects-container",
      cardSelector: ".project-card",
      searchInputId: "projects-search",
      sortSelectId: "projects-sort",
      filterBtnSelector: "#category-filters .cat-btn",
      filterAttr: "data-category",
      gridBtnId: "view-grid-btn",
      listBtnId: "view-list-btn",
      noResultsId: "no-results-state",
      paginationId: "pagination-controls",
      itemsPerPage: 10,
      hasFeatured: false,

      // CSS class sets
      gridContainerClass: "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[300px]",
      listContainerClass: "flex flex-col gap-3",
      gridCardClass: "project-card card card-compact bg-base-200 border border-base-300 shadow-xl overflow-hidden hover:-translate-y-1 transition-transform duration-300 flex flex-col h-full",
      listCardClass: "project-card card bg-base-200 border border-base-300 shadow-sm p-4 hover:border-primary/55 transition-all flex flex-col md:flex-row items-center justify-between gap-4 w-full",
      gridFigureClass: "project-figure relative h-48 bg-base-300 shrink-0 transition-all",
      listFigureClass: "project-figure hidden",
      gridBodyClass: "project-body card-body flex-1 flex flex-col justify-between p-5 transition-all",
      listBodyClass: "project-body card-body flex-1 min-w-0 p-0 flex flex-col md:flex-row md:items-center md:justify-between gap-4 w-full",
      gridFooterClass: "project-footer card-actions justify-start gap-2 pt-4 mt-auto border-t border-base-300",
      listFooterClass: "project-footer flex gap-2 flex-shrink-0 border-t-0 pt-0 mt-0",

      figureSelector: ".project-figure",
      bodySelector: ".project-body",
      footerSelector: ".project-footer"
    });
  }

  // Init
  setup();
  
  // Support Astro view transitions
  document.addEventListener('astro:after-swap', setup);
</script>

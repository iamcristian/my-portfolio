---
import { useTranslations, getProjectsForLang } from "../../i18n/utils";
import ProjectCard from "../ui/cards/ProjectCard.astro";

// SVGs
import SearchIcon from "../../assets/search.svg";
import GridIcon from "../../assets/grid.svg";
import ListIcon from "../../assets/list.svg";
import SortIcon from "../../assets/sort.svg";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
const PROJECTS = getProjectsForLang(lang as any);
---

<main class="max-w-6xl mx-auto px-4 py-12 flex flex-col gap-8 min-h-screen">
  <!-- Header -->
  <div class="text-center space-y-4 max-w-2xl mx-auto">
    <span class="font-mono text-xs tracking-widest uppercase text-primary font-semibold block">// {t("projects.title")}</span>
    <h1 class="text-4xl font-extrabold tracking-tight bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent">
      {t("projects.title")}
    </h1>
    <p class="text-md opacity-80">{t("projects.subtitlePage")}</p>
  </div>

  <!-- Controls: Search, View Toggle, Category Filters, Sort -->
  <div class="flex flex-col gap-6 bg-base-200 p-6 rounded-2xl border border-base-300">
    
    <!-- Top Row: Search + View Toggle -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
      <!-- Search input group -->
      <div class="relative w-full sm:max-w-md">
        <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none opacity-60">
          <SearchIcon class="w-5 h-5" />
        </span>
        <input
          type="text"
          id="projects-search"
          class="input input-bordered w-full pl-10 bg-base-100"
          placeholder={t("projects.searchPlaceholder")}
        />
      </div>

      <!-- View Toggle (Grid / List) using DaisyUI join -->
      <div class="join shrink-0">
        <button id="view-grid-btn" class="btn join-item btn-active btn-square" aria-label={t("projects.viewGrid")}>
          <GridIcon class="w-5 h-5" />
        </button>
        <button id="view-list-btn" class="btn join-item btn-square" aria-label={t("projects.viewList")}>
          <ListIcon class="w-5 h-5" />
        </button>
      </div>
    </div>

    <!-- Bottom Row: Category Filters + Sort Select -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center border-t border-base-300 pt-4">
      <!-- Category Buttons -->
      <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
        <button class="btn btn-sm btn-neutral cat-btn active" data-category="all">{t("projects.all")}</button>
        <button class="btn btn-sm btn-ghost cat-btn" data-category="frontend">{t("projects.frontend")}</button>
        <button class="btn btn-sm btn-ghost cat-btn" data-category="backend">{t("projects.backend")}</button>
        <button class="btn btn-sm btn-ghost cat-btn" data-category="fullstack">{t("projects.fullstack")}</button>
      </div>

      <!-- Sort dropdown -->
      <div class="flex items-center gap-2">
        <SortIcon class="w-5 h-5 opacity-60" />
        <select id="projects-sort" class="select select-bordered select-sm bg-base-100">
          <option value="date-desc">{t("projects.sortDate")} (Newest)</option>
          <option value="date-asc">{t("projects.sortDate")} (Oldest)</option>
          <option value="name-asc">{t("projects.sortName")} (A-Z)</option>
          <option value="name-desc">{t("projects.sortName")} (Z-A)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Projects Container -->
  <div id="projects-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[300px]">
    {
      PROJECTS.map((project) => {
        const title = project.title;
        const description = project.description;
        return (
          <ProjectCard
            project={project}
            data-id={project.id}
            data-category={project.category}
            data-date={project.date}
            data-name={title.toLowerCase()}
            data-tech={project.tech.join(" ").toLowerCase()}
            data-description={description.toLowerCase()}
          />
        );
      })
    }
  </div>

  <!-- Empty State -->
  <div id="no-results-state" class="hidden text-center py-12">
    <p class="text-lg opacity-70">{t("projects.noResults")}</p>
  </div>

  <!-- Pagination -->
  <div class="flex justify-center mt-8" id="pagination-wrapper">
    <div class="join" id="pagination-controls"></div>
  </div>
</main>

<script>
  let currentView = "grid";
  let currentCategory = "all";
  let currentSort = "date-desc";
  let searchQuery = "";
  let currentPage = 1;
  const itemsPerPage = 10;

  // Cache elements
  const container = document.getElementById("projects-container") as HTMLElement;
  const noResults = document.getElementById("no-results-state") as HTMLElement;
  const paginationControls = document.getElementById("pagination-controls") as HTMLElement;
  const allCards = Array.from(document.querySelectorAll(".project-card")) as HTMLElement[];

  const searchInput = document.getElementById("projects-search") as HTMLInputElement;
  const sortSelect = document.getElementById("projects-sort") as HTMLSelectElement;
  const catButtons = document.querySelectorAll(".cat-btn") as NodeListOf<HTMLElement>;
  
  const gridBtn = document.getElementById("view-grid-btn") as HTMLElement;
  const listBtn = document.getElementById("view-list-btn") as HTMLElement;

  // View Switchers
  function updateViewLayout() {
    if (currentView === "grid") {
      gridBtn.classList.add("btn-active");
      listBtn.classList.remove("btn-active");
      
      container.className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6";
      allCards.forEach(card => {
        card.className = "project-card card card-compact bg-base-200 border border-base-300 shadow-xl overflow-hidden hover:-translate-y-1 transition-all duration-300 flex flex-col h-full";
        const fig = card.querySelector(".project-figure");
        if (fig) fig.className = "project-figure relative h-48 bg-base-300 shrink-0 transition-all";
        const body = card.querySelector(".project-body");
        if (body) body.className = "project-body flex-1 flex flex-col justify-between p-5 transition-all";
        const footer = card.querySelector(".project-footer");
        if (footer) footer.className = "project-footer card-actions justify-start gap-2 pt-4 mt-auto border-t border-base-300";
      });
    } else {
      listBtn.classList.add("btn-active");
      gridBtn.classList.remove("btn-active");

      container.className = "flex flex-col gap-3";
      allCards.forEach(card => {
        card.className = "project-card card bg-base-200 border border-base-300 shadow-sm p-4 hover:border-primary/55 transition-all flex flex-col md:flex-row items-center justify-between gap-4 w-full";
        const fig = card.querySelector(".project-figure");
        if (fig) fig.className = "project-figure hidden";
        const body = card.querySelector(".project-body");
        if (body) body.className = "project-body flex-1 min-w-0 p-0 flex flex-col md:flex-row md:items-center md:justify-between gap-4 w-full";
        const footer = card.querySelector(".project-footer");
        if (footer) footer.className = "project-footer flex gap-2 flex-shrink-0 border-t-0 pt-0 mt-0";
      });
    }
  }

  // Filter, Sort, Paginate
  function processProjects() {
    // 1. Filter
    let filtered = allCards.filter(card => {
      // Category match
      const cat = card.getAttribute("data-category");
      const categoryMatch = currentCategory === "all" || cat === currentCategory;

      // Search match
      const title = card.getAttribute("data-name") || "";
      const tech = card.getAttribute("data-tech") || "";
      const desc = card.getAttribute("data-description") || "";
      const searchMatch = !searchQuery || 
        title.includes(searchQuery) || 
        tech.includes(searchQuery) || 
        desc.includes(searchQuery);

      return categoryMatch && searchMatch;
    });

    // 2. Sort
    filtered.sort((a, b) => {
      if (currentSort.startsWith("date")) {
        const dateA = new Date(a.getAttribute("data-date") || "").getTime();
        const dateB = new Date(b.getAttribute("data-date") || "").getTime();
        return currentSort === "date-desc" ? dateB - dateA : dateA - dateB;
      } else {
        const nameA = a.getAttribute("data-name") || "";
        const nameB = b.getAttribute("data-name") || "";
        return currentSort === "name-asc" ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
      }
    });

    // 3. Hide all first
    allCards.forEach(c => c.classList.add("hidden"));

    // 4. Handle Empty State
    if (filtered.length === 0) {
      noResults.classList.remove("hidden");
      paginationControls.innerHTML = "";
      return;
    }
    noResults.classList.add("hidden");

    // 5. Paginate
    const totalPages = Math.ceil(filtered.length / itemsPerPage);
    if (currentPage > totalPages) currentPage = totalPages || 1;

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;
    const paginated = filtered.slice(startIndex, endIndex);

    // Show current page items and reorder in the DOM
    paginated.forEach(c => {
      c.classList.remove("hidden");
      container.appendChild(c);
    });

    // Render pagination controls
    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    paginationControls.innerHTML = "";
    if (totalPages <= 1) return;

    // Prev Button
    const prevBtn = document.createElement("button");
    prevBtn.className = "join-item btn btn-sm" + (currentPage === 1 ? " btn-disabled" : "");
    prevBtn.innerHTML = "«";
    prevBtn.addEventListener("click", () => {
      if (currentPage > 1) {
        currentPage--;
        processProjects();
        window.scrollTo({ top: container.offsetTop - 100, behavior: "smooth" });
      }
    });
    paginationControls.appendChild(prevBtn);

    // Page numbers
    for (let i = 1; i <= totalPages; i++) {
      const pageBtn = document.createElement("button");
      pageBtn.className = `join-item btn btn-sm ${i === currentPage ? "btn-active btn-primary" : ""}`;
      pageBtn.innerText = i.toString();
      pageBtn.addEventListener("click", () => {
        currentPage = i;
        processProjects();
        window.scrollTo({ top: container.offsetTop - 100, behavior: "smooth" });
      });
      paginationControls.appendChild(pageBtn);
    }

    // Next Button
    const nextBtn = document.createElement("button");
    nextBtn.className = "join-item btn btn-sm" + (currentPage === totalPages ? " btn-disabled" : "");
    nextBtn.innerHTML = "»";
    nextBtn.addEventListener("click", () => {
      if (currentPage < totalPages) {
        currentPage++;
        processProjects();
        window.scrollTo({ top: container.offsetTop - 100, behavior: "smooth" });
      }
    });
    paginationControls.appendChild(nextBtn);
  }

  // Debounced Search Handler
  let timer: number;
  searchInput.addEventListener("input", (e) => {
    clearTimeout(timer);
    timer = window.setTimeout(() => {
      searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
      currentPage = 1;
      processProjects();
    }, 300); // 300ms debounce
  });

  // Sort Selector Change
  sortSelect.addEventListener("change", (e) => {
    currentSort = (e.target as HTMLSelectElement).value;
    processProjects();
  });

  // Category Buttons Click
  catButtons.forEach(btn => {
    btn.addEventListener("click", () => {
      catButtons.forEach(b => {
        b.classList.remove("btn-neutral", "active");
        b.classList.add("btn-ghost");
      });
      btn.classList.add("btn-neutral", "active");
      btn.classList.remove("btn-ghost");

      currentCategory = btn.getAttribute("data-category") || "all";
      currentPage = 1;
      processProjects();
    });
  });

  // View Layout Buttons Click
  gridBtn.addEventListener("click", () => {
    if (currentView !== "grid") {
      currentView = "grid";
      updateViewLayout();
    }
  });
  listBtn.addEventListener("click", () => {
    if (currentView !== "list") {
      currentView = "list";
      updateViewLayout();
    }
  });

  // Init
  updateViewLayout();
  processProjects();
</script>

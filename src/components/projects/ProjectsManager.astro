---
import { useTranslations, getProjectsForLang } from "../../i18n/utils";
import ProjectCard from "../ui/cards/ProjectCard.astro";
import PageHeading from "../ui/PageHeading.astro";
import { sortFeaturedFirst } from "../../utils/sort";

import SearchIcon from "../../assets/icons/search.svg";
import GridIcon from "../../assets/icons/grid.svg";
import ListIcon from "../../assets/icons/list.svg";
import SortIcon from "../../assets/icons/sort.svg";

interface Props {
  // Empty props
}

const { lang: langCode } = Astro.locals;
const t = useTranslations(langCode);
const rawProjects = getProjectsForLang(langCode);
const PROJECTS = sortFeaturedFirst(
  rawProjects,
  (p) => p.featured,
  (p) => p.date
);
---

<main
  class="max-w-6xl mx-auto px-4 md:px-8 pt-8 md:pt-12 pb-16 md:pb-24 flex flex-col gap-8 min-h-screen"
>
  <!-- Header -->
  <PageHeading
    subtitle={t("projects.subtitle")}
    title={t("projects.title")}
    description={t("projects.subtitlePage")}
  />

  <!-- Controls: Search, View Toggle, Category Filters, Sort -->
  <div
    class="flex flex-col gap-6 bg-base-200 p-6 rounded-2xl border border-base-300"
  >
    <!-- Top Row: Search + View Toggle -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
      <!-- Search input group -->
      <div class="relative w-full sm:max-w-md">
        <span
          class="absolute inset-y-0 left-3 flex items-center pointer-events-none opacity-60"
        >
          <SearchIcon class="w-5 h-5" />
        </span>
        <input
          type="text"
          id="projects-search"
          class="input input-bordered w-full pl-10 bg-base-100"
          placeholder={t("projects.searchPlaceholder")}
        />
      </div>

      <!-- View Toggle (Grid / List) using DaisyUI join -->
      <div class="join shrink-0">
        <button
          id="view-grid-btn"
          class="btn join-item btn-active btn-square"
          aria-label={t("projects.viewGrid")}
        >
          <GridIcon class="w-5 h-5" />
        </button>
        <button
          id="view-list-btn"
          class="btn join-item btn-square"
          aria-label={t("projects.viewList")}
        >
          <ListIcon class="w-5 h-5" />
        </button>
      </div>
    </div>

    <!-- Bottom Row: Category Filters + Sort & Date Filters Selects -->
    <div
      class="flex flex-col md:flex-row gap-4 justify-between items-center border-t border-base-300 pt-4"
    >
      <!-- Category Buttons -->
      <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
        <button
          class="btn btn-sm btn-neutral cat-btn active"
          data-category="all">{t("projects.all")}</button
        >
        <button class="btn btn-sm btn-outline cat-btn" data-category="frontend"
          >{t("projects.frontend")}</button
        >
        <button class="btn btn-sm btn-outline cat-btn" data-category="backend"
          >{t("projects.backend")}</button
        >
        <button class="btn btn-sm btn-outline cat-btn" data-category="fullstack"
          >{t("projects.fullstack")}</button
        >
      </div>

      <!-- Controls Group -->
      <div
        class="flex flex-wrap items-center justify-center md:justify-end gap-3 w-full md:w-auto"
      >
        <!-- Date Range dropdown -->
        <div class="flex items-center gap-2">
          <span
            class="text-xs opacity-60 font-semibold whitespace-nowrap uppercase tracking-wider"
            >{t("blog.filterDateRange")}</span
          >
          <select
            id="projects-date-range"
            class="select select-bordered select-sm bg-base-100 font-medium text-xs focus:ring-2 focus:ring-primary focus:outline-none"
          >
            <option value="all" selected>{t("blog.dateAll")}</option>
            <option value="yesterday">{t("blog.dateYesterday")}</option>
            <option value="week">{t("blog.dateWeek")}</option>
            <option value="month">{t("blog.dateMonth")}</option>
            <option value="year">{t("blog.dateYear")}</option>
            <option value="custom">{t("blog.dateCustom")}</option>
          </select>
        </div>

        <!-- Custom Date Range Picker Container -->
        <div
          id="projects-custom-date-container"
          class="hidden items-center gap-1 bg-base-100 border border-base-300 rounded-lg p-1 transition-all duration-300"
        >
          <input
            type="date"
            id="projects-start-date"
            class="input input-ghost input-xs bg-transparent w-28 text-[11px] px-1.5 focus:outline-none"
            aria-label={t("blog.startDate")}
          />
          <span class="opacity-40 text-xs px-0.5">-</span>
          <input
            type="date"
            id="projects-end-date"
            class="input input-ghost input-xs bg-transparent w-28 text-[11px] px-1.5 focus:outline-none"
            aria-label={t("blog.endDate")}
          />
        </div>

        <!-- Sort dropdown -->
        <div class="flex items-center gap-2">
          <SortIcon class="w-4 h-4 opacity-60 shrink-0" />
          <select
            id="projects-sort"
            class="select select-bordered select-sm bg-base-100 font-medium text-xs focus:ring-2 focus:ring-primary focus:outline-none"
          >
            <option value="relevance" selected>{t("blog.sortRelevance")}</option
            >
            <option value="date-desc">{t("projects.sortDateNewest")}</option>
            <option value="date-asc">{t("projects.sortDateOldest")}</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Projects Container -->
  <div
    id="projects-container"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[300px]"
  >
    {
      PROJECTS.map((project, index) => {
        const title = project.title;
        const description = project.description;
        return (
          <ProjectCard
            project={project}
            loading={index < 6 ? "eager" : "lazy"}
            showFeaturedBadge={project.featured}
            data-id={project.id}
            data-featured={project.featured ? "true" : "false"}
            data-category={project.category}
            data-date={project.date}
            data-name={title.toLowerCase()}
            data-tech={project.tech.join(" ").toLowerCase()}
            data-description={description.toLowerCase()}
          />
        );
      })
    }
  </div>

  <!-- Empty State -->
  <div id="no-results-state" class="hidden text-center py-12">
    <p class="text-lg opacity-70">{t("projects.noResults")}</p>
  </div>

  <!-- Pagination -->
  <div class="flex justify-center mt-8" id="pagination-wrapper">
    <div class="join" id="pagination-controls"></div>
  </div>
</main>

<script>
  import { initListManager } from "../../scripts/list-manager";

  function setup() {
    initListManager({
      containerId: "projects-container",
      cardSelector: ".project-card",
      searchInputId: "projects-search",
      sortSelectId: "projects-sort",
      filterBtnSelector: "#category-filters .cat-btn",
      filterAttr: "data-category",
      gridBtnId: "view-grid-btn",
      listBtnId: "view-list-btn",
      noResultsId: "no-results-state",
      paginationId: "pagination-controls",
      itemsPerPage: 10,
      hasFeatured: true,
      dateRangeSelectId: "projects-date-range",
      customDateContainerId: "projects-custom-date-container",
      startDateInputId: "projects-start-date",
      endDateInputId: "projects-end-date",

      // CSS class sets
      gridContainerClass:
        "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[300px]",
      listContainerClass: "flex flex-col gap-3",
      gridCardClass:
        "project-card card card-compact bg-base-200 border border-base-300 shadow-xl overflow-hidden hover:-translate-y-1 transition-transform duration-300 flex flex-col h-full",
      listCardClass:
        "project-card card bg-base-200 border border-base-300 shadow-sm p-4 hover:border-primary/55 transition-all flex flex-col md:flex-row items-center justify-between gap-4 w-full",
      gridFigureClass:
        "project-figure relative h-48 bg-base-300 shrink-0 transition-all",
      listFigureClass: "project-figure hidden",
      gridBodyClass:
        "project-body card-body flex-1 flex flex-col justify-between p-5 transition-all",
      listBodyClass:
        "project-body card-body flex-1 min-w-0 p-0 flex flex-col md:flex-row md:items-center md:justify-between gap-4 w-full",
      gridFooterClass:
        "project-footer card-actions justify-start gap-2 pt-4 mt-auto border-t border-base-300",
      listFooterClass:
        "project-footer flex gap-2 flex-shrink-0 border-t-0 pt-0 mt-0",

      figureSelector: ".project-figure",
      bodySelector: ".project-body",
      footerSelector: ".project-footer",
    });
  }

  // Init
  setup();

  // Support Astro view transitions
  document.addEventListener("astro:after-swap", setup);
</script>

---
import { useTranslations } from "../../i18n/utils";

const { lang } = Astro.locals;
const t = useTranslations(lang);

// Mapeo de idiomas de tu portafolio a los soportados por Giscus
const giscusLangMap: Record<string, string> = {
  en: "en",
  es: "es",
  de: "de",
  ja: "ja",
  ru: "ru",
};
const giscusLang = giscusLangMap[lang] || "en";

// Repositorio y credenciales provistos por el usuario
const repo = "iamcristian/my-portfolio";
const repoId = "R_kgDOS3yNtQ";
const category = "Announcements";
const categoryId = "DIC_kwDOS3yNtc4C-918";
---

<div class="giscus-wrapper mt-12 pt-8 border-t border-base-300">
  <h2 class="text-xl font-bold mb-6 text-base-content/90">
    {t("blog.comments")}
  </h2>

  <!-- Elemento personalizado de Giscus -->
  <giscus-widget
    id="comments-widget"
    repo={repo}
    repoid={repoId}
    category={category}
    categoryid={categoryId}
    mapping="pathname"
    strict="0"
    reactionsenabled="1"
    emitmetadata="0"
    inputposition="bottom"
    theme="light"
    lang={giscusLang}
    loading="lazy"></giscus-widget>
</div>

<script>
  function setupGiscusTheme() {
    const widget = document.getElementById("comments-widget");
    if (!widget) return;

    const currentTheme = document.documentElement.getAttribute("data-theme");
    const isDark = currentTheme !== "light";
    const giscusTheme = isDark ? "dark" : "light";

    widget.setAttribute("theme", giscusTheme);
  }

  /**
   * Re-mount the giscus-widget custom element to force it to reinitialize.
   * After a View Transition, the web component's iframe may still show comments
   * from the previous page. Detaching and re-attaching the element triggers
   * disconnectedCallback → connectedCallback, which creates a fresh iframe
   * using the current window.location.pathname.
   */
  function refreshGiscusWidget() {
    const widget = document.getElementById("comments-widget");
    if (!widget?.parentNode) return;

    const parent = widget.parentNode;
    const next = widget.nextSibling;

    // Remove → disconnectedCallback (destroys old iframe)
    parent.removeChild(widget);

    // Re-add → connectedCallback (creates new iframe with current pathname)
    requestAnimationFrame(() => {
      parent.insertBefore(widget, next);
      setupGiscusTheme();
    });
  }

  let giscusObserver: IntersectionObserver | null = null;

  function initGiscusLazyLoad() {
    giscusObserver?.disconnect();
    const wrapper = document.querySelector(".giscus-wrapper");
    if (!wrapper) return;

    giscusObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const scriptAlreadyLoaded = !!document.querySelector('script[src="https://esm.sh/giscus"]');

          if (!scriptAlreadyLoaded) {
            // First blog visit: load the giscus web component script
            const script = document.createElement("script");
            script.type = "module";
            script.src = "https://esm.sh/giscus";
            script.async = true;
            document.head.appendChild(script);
          } else {
            // View Transition navigation: script is loaded but the widget
            // may show stale comments — force re-creation for current URL
            refreshGiscusWidget();
          }

          giscusObserver?.disconnect();
          giscusObserver = null;
        }
      });
    }, { rootMargin: "200px" });

    giscusObserver.observe(wrapper);
  }

  // ── Initial setup ──
  setupGiscusTheme();
  initGiscusLazyLoad();

  // ── Theme change observer ──
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === "data-theme") {
        setupGiscusTheme();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // ── Astro View Transitions compatibility ──
  document.addEventListener("astro:page-load", () => {
    setupGiscusTheme();
    initGiscusLazyLoad();
  });

  document.addEventListener("astro:before-swap", () => {
    giscusObserver?.disconnect();
    giscusObserver = null;
  });
</script>

---
import { useTranslations } from "../../i18n/utils";

const { lang } = Astro.locals;
const t = useTranslations(lang);

// Mapping of portfolio languages to those supported by Giscus
const giscusLangMap: Record<string, string> = {
  en: "en",
  es: "es",
  de: "de",
  ja: "ja",
  ru: "ru",
};
const giscusLang = giscusLangMap[lang] || "en";

// Repository and credentials provided by the user
const repo = "iamcristian/my-portfolio";
const repoId = "R_kgDOS3yNtQ";
const category = "Announcements";
const categoryId = "DIC_kwDOS3yNtc4C-918";
---

<div class="giscus-wrapper mt-12 pt-8 border-t border-base-300">
  <h2 class="text-xl font-bold mb-6 text-base-content/90">
    {t("blog.comments")}
  </h2>

  <!-- Container for dynamic initialization of Giscus -->
  <div
    id="giscus-container"
    data-repo={repo}
    data-repoid={repoId}
    data-category={category}
    data-categoryid={categoryId}
    data-lang={giscusLang}
  ></div>
</div>

<script>
  function setupGiscusTheme() {
    const widget = document.getElementById("comments-widget");
    if (!widget) return;

    const currentTheme = document.documentElement.getAttribute("data-theme");
    const isDark = currentTheme !== "light";
    const giscusTheme = isDark ? "dark" : "light";

    widget.setAttribute("theme", giscusTheme);
  }

  function createGiscusWidget() {
    const container = document.getElementById("giscus-container");
    if (!container) return;

    // Avoid duplicates if the widget already exists in the DOM
    if (document.getElementById("comments-widget")) return;

    const widget = document.createElement("giscus-widget");
    widget.setAttribute("id", "comments-widget");
    widget.setAttribute("repo", container.getAttribute("data-repo") || "");
    widget.setAttribute("repoid", container.getAttribute("data-repoid") || "");
    widget.setAttribute("category", container.getAttribute("data-category") || "");
    widget.setAttribute("categoryid", container.getAttribute("data-categoryid") || "");
    widget.setAttribute("mapping", "pathname");
    widget.setAttribute("strict", "0");
    widget.setAttribute("reactionsenabled", "1");
    widget.setAttribute("emitmetadata", "0");
    widget.setAttribute("inputposition", "bottom");
    widget.setAttribute("lang", container.getAttribute("data-lang") || "en");
    widget.setAttribute("loading", "lazy");

    // Configure initial theme
    const currentTheme = document.documentElement.getAttribute("data-theme");
    const isDark = currentTheme !== "light";
    widget.setAttribute("theme", isDark ? "dark" : "light");

    container.appendChild(widget);
  }

  let giscusObserver: IntersectionObserver | null = null;

  function initGiscusLazyLoad() {
    giscusObserver?.disconnect();
    const wrapper = document.querySelector(".giscus-wrapper");
    if (!wrapper) return;

    giscusObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const scriptAlreadyLoaded = !!document.querySelector('script[src="https://esm.sh/giscus"]');

          if (!scriptAlreadyLoaded) {
            // First visit: load the Giscus component script
            const script = document.createElement("script");
            script.type = "module";
            script.src = "https://esm.sh/giscus";
            script.async = true;
            document.head.appendChild(script);
          }

          // Create and append the widget. If the script is still loading,
          // the browser will automatically upgrade the element when it finishes.
          createGiscusWidget();

          giscusObserver?.disconnect();
          giscusObserver = null;
        }
      });
    }, { rootMargin: "200px" });

    giscusObserver.observe(wrapper);
  }

  // ── Global theme change observer ──
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === "data-theme") {
        setupGiscusTheme();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // ── Astro View Transitions compatibility ──
  document.addEventListener("astro:page-load", () => {
    initGiscusLazyLoad();
  });

  document.addEventListener("astro:before-swap", () => {
    giscusObserver?.disconnect();
    giscusObserver = null;
  });
</script>

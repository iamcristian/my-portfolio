---
import { SITE } from "../config/site";
import { getLang, useTranslations } from "../i18n/utils";
import { getCollection } from "astro:content";
import meImage from "../assets/images/me.webp";

export interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  imageAlt?: string;
  type?: "website" | "article";
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const {
  type = "website",
  publishDate,
  updatedDate,
  tags,
} = Astro.props;

// Determine current locale & translation helper
const lang = getLang(Astro.currentLocale || Astro.params.lang);
const t = useTranslations(lang);

// Get absolute canonical URLs
const siteUrl = Astro.site?.origin || SITE.url || "https://cristianarando.vercel.app";
const cleanSiteUrl = siteUrl.replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, cleanSiteUrl).href;

// Page type detection
const pathname = Astro.url.pathname;
const isHome = pathname === `/${lang}/` || pathname === `/${lang}` || pathname === "/";
const isProjects = pathname.includes("/projects");
const isBlogIndex = (pathname.endsWith("/blog") || pathname.endsWith("/blog/")) && !Astro.params.slug;

// 1. Determine localized title
let title = Astro.props.title;
if (title) {
  if (type === "article") {
    title = `${title} | Blog | ${t("home.name")}`;
  } else {
    title = `${title} | ${t("home.name")}`;
  }
} else {
  if (isHome) {
    title = `${t("home.name")} — ${t("home.subtitle")}`;
  } else if (isProjects) {
    title = `${t("projects.title")} | ${t("home.name")}`;
  } else if (isBlogIndex) {
    title = `${t("blog.title")} | ${t("home.name")}`;
  } else {
    title = t("site.title") || SITE.title;
  }
}

// 2. Determine localized description
let description = Astro.props.description;
if (!description) {
  if (isHome) {
    description = t("home.tagline") || t("site.description") || SITE.description;
  } else if (isProjects) {
    description = t("projects.subtitlePage") || t("site.description") || SITE.description;
  } else if (isBlogIndex) {
    description = t("blog.subtitlePage") || t("site.description") || SITE.description;
  } else {
    description = t("site.description") || SITE.description;
  }
}

// 3. OpenGraph locale mapping
const OG_LOCALES: Record<string, string> = {
  en: "en_US",
  es: "es_ES",
  de: "de_DE",
  ru: "ru_RU",
  ja: "ja_JP",
};
const ogLocale = OG_LOCALES[lang] || "en_US";

// 4. Resolve multilingual alternates (hreflang)
const locales = ["en", "es", "de", "ru", "ja"];
let activeLocales = [...locales];

// If it's a blog post, only output alternate hreflang tags for languages that actually have this post
if (Astro.params.slug && pathname.includes("/blog/")) {
  const slug = Astro.params.slug;
  const siblingPosts = await getCollection("blog", (post) => post.data.slug === slug && !post.data.draft);
  activeLocales = siblingPosts.map((post) => post.data.lang);
}

// Generate canonical alternates
const alternateUrls = activeLocales.map((locale) => {
  const segments = pathname.split("/");
  if (segments.length > 1 && locales.includes(segments[1])) {
    segments[1] = locale;
  }
  const newPathname = segments.join("/");
  return {
    lang: locale,
    url: new URL(newPathname, cleanSiteUrl).href,
  };
});

// Default fallback language URL (x-default) pointing to the English ('en') version of the current page
const defaultSegments = pathname.split("/");
if (defaultSegments.length > 1 && locales.includes(defaultSegments[1])) {
  defaultSegments[1] = "en";
}
const defaultUrl = new URL(defaultSegments.join("/"), cleanSiteUrl).href;

// 5. OpenGraph & Twitter Image
const imageSource = Astro.props.image || meImage;
const fullImageUrl = typeof imageSource === "string" 
  ? (imageSource.startsWith("http") ? imageSource : `${cleanSiteUrl}${imageSource}`)
  : new URL(imageSource.src, cleanSiteUrl).href;
const fullImageAlt = Astro.props.imageAlt || title || t("home.name");

// Extract dynamic width and height from ImageMetadata if available
const imageWidth = typeof imageSource === "object" ? imageSource.width.toString() : "1200";
const imageHeight = typeof imageSource === "object" ? imageSource.height.toString() : "630";
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta http-equiv="Content-Language" content={lang} />

<!-- Enable large image previews in Google Discover and other crawlers -->
<meta
  name="robots"
  content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>

<!-- Language alternates for SEO -->
{
  alternateUrls.map(({ lang: altLang, url }) => (
    <link rel="alternate" hreflang={altLang} href={url} />
  ))
}
<link rel="alternate" hreflang="x-default" href={defaultUrl} />

<!-- RSS Feed Autodiscovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${t("site.title") || SITE.title} RSS Feed`}
  href={new URL(`/${lang}/rss.xml`, cleanSiteUrl).href}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === "article" ? "article" : "website"} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={fullImageAlt} />
<meta property="og:image:width" content={imageWidth} />
<meta property="og:image:height" content={imageHeight} />
<meta property="og:locale" content={ogLocale} />
{
  activeLocales
    .filter((l) => l !== lang)
    .map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALES[l] || "en_US"} />
    ))
}
<meta property="og:site_name" content={t("home.name")} />

<!-- Article-specific meta tags for blog posts -->
{
  type === "article" && (
    <>
      {publishDate && (
        <meta
          property="article:published_time"
          content={publishDate.toISOString()}
        />
      )}
      {updatedDate && (
        <meta
          property="article:modified_time"
          content={updatedDate.toISOString()}
        />
      )}
      <meta property="article:author" content={t("home.name")} />
      <meta property="article:section" content="Technology" />
      {tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}

<!-- Twitter / X -->
<!-- Note: Social card platforms (X, Discord, Slack, etc.) still use standard twitter: tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={fullImageAlt} />
{SITE.social.twitter && <meta name="twitter:creator" content={SITE.social.twitter} />}


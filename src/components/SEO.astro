---
import { SITE } from "../config/site";
import { getCollection } from "astro:content";
import { resolveSEOData, getAlternateUrls } from "../utils/seo";
import { OG_LOCALES, locales } from "../i18n/ui";

export interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  imageAlt?: string;
  type?: "website" | "article";
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { type = "website", publishDate, updatedDate, tags } = Astro.props;

const { lang } = Astro.locals;
const slug = Astro.params.slug;

const seo = resolveSEOData(Astro.props, Astro.url, lang, slug);
const t = seo.t;

// Resolve multilingual alternates (hreflang)
let activeLocales = [...locales];

// If it's a blog post, only output alternate hreflang tags for languages that actually have this post
if (slug && seo.pathname.includes("/blog/")) {
  const siblingPosts = await getCollection(
    "blog",
    (post) => post.data.slug === slug && !post.data.draft,
  );
  activeLocales = siblingPosts.map(
    (post) => post.data.lang as typeof locales[number],
  );
}

const alternateUrls = getAlternateUrls(
  seo.pathname,
  activeLocales,
  seo.cleanSiteUrl,
);
---

<!-- Primary Meta Tags -->
<title>{seo.title}</title>
<meta name="title" content={seo.title} />
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonicalUrl} />
<meta http-equiv="Content-Language" content={seo.lang} />

<!-- Enable large image previews in Google Discover and other crawlers -->
<meta
  name="robots"
  content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>

<!-- Language alternates for SEO -->
{
  alternateUrls.map(({ lang: altLang, url }) => (
    <link rel="alternate" hreflang={altLang} href={url} />
  ))
}
<link rel="alternate" hreflang="x-default" href={seo.defaultUrl} />

<!-- RSS Feed Autodiscovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${t("site.title") || SITE.title} RSS Feed`}
  href={new URL(`/${seo.lang}/rss.xml`, seo.cleanSiteUrl).href}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === "article" ? "article" : "website"} />
<meta property="og:url" content={seo.canonicalUrl} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:image" content={seo.imageUrl} />
<meta property="og:image:alt" content={seo.fullImageAlt} />
<meta property="og:image:width" content={seo.imageWidth} />
<meta property="og:image:height" content={seo.imageHeight} />
<meta property="og:locale" content={seo.ogLocale} />
{
  activeLocales
    .filter((l) => l !== seo.lang)
    .map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALES[l] || "en_US"} />
    ))
}
<meta property="og:site_name" content={t("home.name") || SITE.name} />

<!-- Article-specific meta tags for blog posts -->
{
  type === "article" && (
    <>
      {publishDate && (
        <meta
          property="article:published_time"
          content={publishDate.toISOString()}
        />
      )}
      {updatedDate && (
        <>
          <meta
            property="article:modified_time"
            content={updatedDate.toISOString()}
          />
          <meta http-equiv="last-modified" content={updatedDate.toISOString()} />
        </>
      )}
      <meta property="article:author" content={t("home.name") || SITE.name} />
      <meta property="article:section" content="Technology" />
      {tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}

<!-- Twitter / X -->
<!-- Note: Social card platforms (X, Discord, Slack, etc.) still use standard twitter: tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={seo.canonicalUrl} />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.imageUrl} />
<meta name="twitter:image:alt" content={seo.fullImageAlt} />
{
  SITE.social.twitter && (
    <meta name="twitter:creator" content={SITE.social.twitter} />
  )
}

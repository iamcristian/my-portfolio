---
import "@assets/app.css";
import SEO from "@components/SEO.astro";
import StructuredData from "@components/StructuredData.astro";
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  imageAlt?: string;
  type?: "website" | "article";
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  structuredDataType?: "profile" | "collection";
  wordCount?: number;
}

const lang = Astro.currentLocale || "en";
---

<!doctype html>
<html lang={lang} class="preload">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Web App Manifest & Mobile optimization -->
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#181818" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <SEO {...Astro.props} />
    <StructuredData {...Astro.props} />
    <ClientRouter />

    <script is:inline>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const theme =
            stored ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "business"
              : "light");
          document.documentElement.setAttribute("data-theme", theme);
        }
        applyTheme();
        if (!window.__themeListenerAttached) {
          document.addEventListener("astro:after-swap", applyTheme);
          window.__themeListenerAttached = true;
        }
      })();
    </script>
    <script>
      import { themeChange } from "theme-change";

      document.addEventListener("astro:page-load", () => {
        themeChange(false);
        // Remove preload class after page load to re-enable transitions
        document.documentElement.classList.remove("preload");
      });
    </script>
    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
